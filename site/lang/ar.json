  "pricing.faq.title": "\u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0634\u0627\u0626\u0639\u0629",
  "pricing.faq.q1": "\u0645\u0627 \u0647\u064a \u0631\u0645\u0648\u0632 SIMY\u061f",
  "pricing.faq.a1": "\u0627\u0644\u0631\u0645\u0648\u0632 \u0647\u064a \u0627\u0644\u0639\u0645\u0644\u0629 \u0627\u0644\u062a\u064a \u064a\u0633\u062a\u062e\u062f\u0645\u0647\u0627 \u0645\u062d\u0631\u0643 \u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a \u0641\u064a SIMY. \u0643\u0644 \u0645\u0647\u0645\u0629 \u0625\u0646\u0634\u0627\u0621 \u0643\u0648\u062f \u0648\u0645\u0631\u0627\u062c\u0639\u0629 \u0648\u0637\u0644\u0628 \u0633\u062d\u0628 \u062a\u0633\u062a\u0647\u0644\u0643 \u0631\u0645\u0648\u0632\u064b\u0627 \u062d\u0633\u0628 \u0627\u0644\u062a\u0639\u0642\u064a\u062f. \u062a\u062a\u0636\u0645\u0646 \u062e\u0637\u062a\u0643 \u062a\u062e\u0635\u064a\u0635\u064b\u0627 \u0634\u0647\u0631\u064a\u064b\u0627 \u0644\u0644\u0631\u0645\u0648\u0632 \u064a\u064f\u0639\u0627\u062f \u062a\u0639\u064a\u064a\u0646\u0647 \u0641\u064a \u0643\u0644 \u062f\u0648\u0631\u0629 \u0641\u0648\u062a\u0631\u0629.",
  "pricing.faq.q2": "\u0647\u0644 \u064a\u0645\u0643\u0646\u0646\u064a \u062a\u063a\u064a\u064a\u0631 \u0627\u0644\u062e\u0637\u0629 \u0641\u064a \u0623\u064a \u0648\u0642\u062a\u061f",
  "pricing.faq.a2": "\u0646\u0639\u0645. \u064a\u0645\u0643\u0646\u0643 \u0627\u0644\u062a\u0631\u0642\u064a\u0629 \u0623\u0648 \u0627\u0644\u062a\u062e\u0641\u064a\u0636 \u0641\u064a \u0623\u064a \u0648\u0642\u062a. \u0639\u0646\u062f \u0627\u0644\u062a\u0631\u0642\u064a\u0629 \u062a\u062d\u0635\u0644 \u0639\u0644\u0649 \u0627\u0644\u0631\u0645\u0648\u0632 \u0627\u0644\u0625\u0636\u0627\u0641\u064a\u0629 \u0641\u0648\u0631\u064b\u0627. \u0639\u0646\u062f \u0627\u0644\u062a\u062e\u0641\u064a\u0636 \u064a\u0633\u0631\u064a \u0627\u0644\u062a\u063a\u064a\u064a\u0631 \u0645\u0646 \u0628\u062f\u0627\u064a\u0629 \u062f\u0648\u0631\u0629 \u0627\u0644\u0641\u0648\u062a\u0631\u0629 \u0627\u0644\u062a\u0627\u0644\u064a\u0629.",
  "pricing.faq.q3": "\u0645\u0627\u0630\u0627 \u064a\u062d\u062f\u062b \u0625\u0630\u0627 \u0646\u0641\u062f\u062a \u0627\u0644\u0631\u0645\u0648\u0632\u061f",
  "pricing.faq.a3": "\u0625\u0630\u0627 \u0627\u0633\u062a\u0646\u0641\u062f\u062a \u062a\u062e\u0635\u064a\u0635\u0643 \u0627\u0644\u0634\u0647\u0631\u064a\u060c \u064a\u0645\u0643\u0646\u0643 \u0634\u0631\u0627\u0621 \u062d\u0632\u0645 \u0631\u0645\u0648\u0632 \u0625\u0636\u0627\u0641\u064a\u0629 \u0623\u0648 \u062a\u0631\u0642\u064a\u0629 \u062e\u0637\u062a\u0643. \u062a\u0638\u0644 \u0623\u0639\u0645\u0627\u0644\u0643 \u0648\u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0627\u0644\u062d\u0627\u0644\u064a\u0629 \u0645\u062a\u0627\u062d\u0629 \u0628\u0627\u0644\u0643\u0627\u0645\u0644.",
  "pricing.faq.q4": "\u0647\u0644 \u064a\u062a\u0645 \u062a\u0631\u062d\u064a\u0644 \u0627\u0644\u0631\u0645\u0648\u0632 \u063a\u064a\u0631 \u0627\u0644\u0645\u0633\u062a\u062e\u062f\u0645\u0629\u061f",
  "pricing.faq.a4": "\u064a\u062a\u0645 \u0625\u0639\u0627\u062f\u0629 \u062a\u0639\u064a\u064a\u0646 \u062a\u062e\u0635\u064a\u0635\u0627\u062a \u0627\u0644\u0631\u0645\u0648\u0632 \u0627\u0644\u0634\u0647\u0631\u064a\u0629 \u0641\u064a \u0643\u0644 \u062f\u0648\u0631\u0629 \u0648\u0644\u0627 \u064a\u062a\u0645 \u062a\u0631\u062d\u064a\u0644\u0647\u0627. \u0644\u0644\u062d\u0635\u0648\u0644 \u0639\u0644\u0649 \u0623\u0642\u0635\u0649 \u0645\u0631\u0648\u0646\u0629\u060c \u0641\u0643\u0651\u0631 \u0641\u064a \u062e\u0637\u0629 Scale \u0623\u0648 \u062a\u0648\u0627\u0635\u0644 \u0645\u0639\u0646\u0627 \u0644\u062e\u064a\u0627\u0631\u0627\u062a Enterprise.",
  "pricing.faq.q5": "\u0647\u0644 \u0627\u0644\u0641\u0648\u062a\u0631\u0629 \u0627\u0644\u0633\u0646\u0648\u064a\u0629 \u0645\u062a\u0627\u062d\u0629\u061f",
  "pricing.faq.a5": "\u0646\u0639\u0645. \u0627\u062e\u062a\u0631 \u0627\u0644\u0641\u0648\u062a\u0631\u0629 \u0627\u0644\u0633\u0646\u0648\u064a\u0629 \u0644\u062a\u0648\u0641\u064a\u0631 17% \u0645\u0642\u0627\u0631\u0646\u0629 \u0628\u0627\u0644\u0633\u0639\u0631 \u0627\u0644\u0634\u0647\u0631\u064a. \u064a\u062a\u0645 \u0627\u0644\u062f\u0641\u0639 \u0645\u0642\u062f\u0645\u064b\u0627 \u0644\u0644\u0639\u0627\u0645 \u0627\u0644\u0643\u0627\u0645\u0644.",

